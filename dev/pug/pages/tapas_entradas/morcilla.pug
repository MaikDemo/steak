extends ../../templates/template.pug
include ../../mixins/plate
block append config
    //- cambiar la varialbe | PAGE | para modificar el titulo de la pagina
    - page = "Morcillas"
    - descripcion = "2 morcillas servidas con chimichurri y pan tostado con ajo."
block content
    .content__plate
        //- ingresar los datos para que se vea en la pagina en el siguiente orden
        //- imgajen | titulo | precio | ingredientes
        +plate('media/tapas_entradas/MORCILLA.jpg',page,'Bs 28','',descripcion,sponsors[5])
    include ../../blocks/btn_atras
    +btn("tapas_entradas")